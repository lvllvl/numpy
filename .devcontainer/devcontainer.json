{
    // Use the Python 3.12 dev container image (includes conda/miniconda).
    "image": "mcr.microsoft.com/devcontainers/python:3.12",

    // The script we’ll write below will run automatically after the container is created.
    "onCreateCommand": ".devcontainer/setup.sh",

    // If you want to run additional commands after container creation, you could set "postCreateCommand" here.

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    }
}
